{
  "name": "airfetch",
  "productName": "Airfetch",
  "version": "0.1.1",
  "description": "Cross-platform video & audio downloader.",
  "main": "main.js",
  "private": true,
  "author": "Peter Day",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dev": "AIRFETCH_DEV=1 npm run build && AIRFETCH_DEV=1 electron .",
    "dist": "npm run build && electron-builder --mac --linux --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "vue": "^3.5.33"
  },
  "build": {
    "appId": "com.peterday.airfetch",
    "productName": "Airfetch",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**",
      "renderer/index.html",
      "icons/**",
      "assets/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "synopsis": "Video & audio downloader",
      "maintainer": "Peter Day"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    }
  }
}
